# -------------------------------------------------------
# VitalSync Environment Variables
# -------------------------------------------------------
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# NEVER commit the .env file to Git — it has secrets!
# This .env.example file IS committed so others know
# what variables are needed.
# -------------------------------------------------------

# --- MySQL Database ---
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=vitalsync
MYSQL_USER=vitalsync_user
MYSQL_PASSWORD=vitalsync_pass

# This is the connection string Prisma uses to talk to MySQL.
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://vitalsync_user:vitalsync_pass@localhost:3307/vitalsync

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Server ---
PORT=4000
NODE_ENV=development

# --- JWT Auth (we'll use these in Step 5) ---
JWT_ACCESS_SECRET=change-me-to-a-random-string
JWT_REFRESH_SECRET=change-me-to-a-different-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- AI / External APIs (we'll use these later) ---
# GEMINI_API_KEY=
# TAVILY_API_KEY=
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=
