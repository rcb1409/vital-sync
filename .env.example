# -------------------------------------------------------
# VitalSync Environment Variables
# -------------------------------------------------------
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# NEVER commit the .env file to Git — it has secrets!
# This .env.example file IS committed so others know
# what variables are needed.
# -------------------------------------------------------

# --- MySQL Database ---
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=vitalsync
MYSQL_USER=vitalsync_user
MYSQL_PASSWORD=vitalsync_pass

# This is the connection string Prisma uses to talk to MySQL.
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://vitalsync_user:vitalsync_pass@localhost:3307/vitalsync

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Server ---
PORT=4000
NODE_ENV=development

# --- JWT Auth ---
JWT_ACCESS_SECRET=change-me-to-a-random-string
JWT_REFRESH_SECRET=change-me-to-a-different-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- Strava OAuth ---
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# --- AWS Bedrock (AI Model) ---
# Credentials come from the AWS provider chain (CLI / env / IAM role).
# In production (ECS), the task IAM role handles auth — no keys needed here.
# Locally, run `aws configure` once and these are read automatically.
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# --- Langfuse (AI Observability) ---
# Get keys from https://cloud.langfuse.com → Settings → API Keys
# Use your DEV project keys here. Production uses separate keys in AWS Secrets Manager.
# Both keys are optional — if missing, tracing is silently disabled (app still works).
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# --- Tavily (Web Search Tool for AI Coach) ---
# Get a free key at https://app.tavily.com
# Optional — if missing, the web_search tool is disabled
TAVILY_API_KEY=tvly-...
