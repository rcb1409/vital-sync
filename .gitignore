
# Dependencies (installed via npm install, never committed)
# -------------------------------------------------------
node_modules/

# -------------------------------------------------------
# Environment files (contain secrets like passwords)
# -------------------------------------------------------
.env
.env.local
.env.production

# -------------------------------------------------------
# Build outputs (generated files, not source code)
# -------------------------------------------------------
dist/
build/

# -------------------------------------------------------
# Prisma
# -------------------------------------------------------
server/prisma/migrations/**/migration_lock.toml

# -------------------------------------------------------
# IDE and OS files
# -------------------------------------------------------
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# -------------------------------------------------------
# Logs
# -------------------------------------------------------
*.log
npm-debug.log*

# -------------------------------------------------------
# Docker volumes (data persisted by Docker)
# -------------------------------------------------------
docker-data/
